# Public app URL for canonical and metadata links
NEXT_PUBLIC_SITE_URL=

# Supabase project URL (for client and server usage)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key (safe for browser/client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase publishable key (if used by SDK or tooling)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional mirrored server-side keys
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Supabase service role key (server-side only, never expose in client)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase secrets used by backend integrations (server-side only)
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=

# Optional Postgres connection variables (only if direct DB access is used)
POSTGRES_DATABASE=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_PRISMA_URL=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=